# Gemini API key for board recognition fix (removes OCR errors, corrects non-words)
# Get a key at https://aistudio.google.com/app/apikey
# Production: Add GEMINI_API_KEY in Vercel Project Settings → Environment Variables
# Local: Copy to .env.local and run `vercel dev` (not `npm run dev`) to test the fix
GEMINI_API_KEY=your_gemini_api_key_here
