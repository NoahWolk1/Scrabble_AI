{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "functions": {
    "api/gemini/transcribe.ts": { "maxDuration": 60 },
    "api/gemini/chat.ts": { "maxDuration": 60 },
    "api/gemini/recognize-board.ts": { "maxDuration": 60 }
  },
  "rewrites": [{ "source": "/((?!api/).*)", "destination": "/index.html" }]
}
